---
import faq from '../data/faq.json';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item: { q: string; a: string }) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a }
  }))
};
---
<section class="faq section" id="faq">
  <div class="container faq__grid">
    <div>
      <span class="section__eyebrow">FAQ</span>
      <h2 class="section__title">Common <span class="highlight">Questions</span></h2>
      <p class="section__lead">More in the <a href="/faq">full FAQ →</a></p>
    </div>
    <div class="faq__list">
      {faq.map((item: { q: string; a: string }) => (
        <details class="faq__item">
          <summary>{item.q}</summary>
          <p>{item.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<style>
  .faq__grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 3rem; }
  .faq__item { border-bottom: 1px solid var(--color-border); padding: 1.2rem 0; }
  .faq__item summary { cursor: pointer; font-weight: 600; color: var(--color-text); list-style: none; }
  .faq__item summary::-webkit-details-marker { display: none; }
  .faq__item summary::before { content: '+'; color: var(--color-accent); margin-right: 0.7rem; font-weight: 700; }
  .faq__item[open] summary::before { content: '−'; }
  .faq__item p { margin-top: 0.8rem; color: var(--color-text-muted); font-size: 0.95rem; }
  @media (max-width: 768px) {
    .faq__grid { grid-template-columns: 1fr; }
  }
</style>
