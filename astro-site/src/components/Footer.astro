---
const links = [
  { href: '/privacy-policy', label: 'Privacy' },
  { href: '/terms', label: 'Terms' },
  { href: '/security', label: 'Security' },
  { href: '/contact', label: 'Contact' },
];
---
<footer class="border-t border-stone-200 bg-white mt-20">
  <div class="max-w-7xl mx-auto px-6 py-12">
    <div class="grid md:grid-cols-4 gap-8">
      <div>
        <div class="text-2xl font-bold mb-2" style="font-family: var(--font-serif);">
          personalai<span style="color: var(--color-gold);">.cloud</span>
        </div>
        <p class="text-sm text-stone-600">Your Personal AI, Everywhere You Are.</p>
      </div>
      <div>
        <h4 class="font-semibold mb-3 text-stone-900">Product</h4>
        <ul class="space-y-2 text-sm text-stone-600">
          <li><a href="/whatsapp" class="hover:text-stone-900">WhatsApp</a></li>
          <li><a href="/android" class="hover:text-stone-900">Android</a></li>
          <li><a href="/pricing" class="hover:text-stone-900">Pricing</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-semibold mb-3 text-stone-900">Resources</h4>
      <ul class="space-y-2 text-sm text-stone-600">
        <li><a href="/docs" class="hover:text-stone-900">Docs</a></li>
        <li><a href="/blog" class="hover:text-stone-900">Blog</a></li>
        <li><a href="/changelog" class="hover:text-stone-900">Changelog</a></li>
        <li><a href="/llms.txt" class="hover:text-stone-900">LLMs.txt</a></li>
        <li><a href="/llms-full.txt" class="hover:text-stone-900">LLMs Full</a></li>
        <li><a href="/ai-policy.txt" class="hover:text-stone-900">AI Policy</a></li>
        <li><a href="/ai.txt" class="hover:text-stone-900">AI</a></li>
      </ul>
      </div>
      <div>
        <h4 class="font-semibold mb-3 text-stone-900">Legal</h4>
        <ul class="space-y-2 text-sm text-stone-600">
          {links.map(link => (
            <li><a href={link.href} class="hover:text-stone-900">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
    <div class="border-t border-stone-200 mt-12 pt-8 text-center text-sm text-stone-500">
      © {new Date().getFullYear()} personalai.cloud. All rights reserved.
    </div>
  </div>
</footer>
