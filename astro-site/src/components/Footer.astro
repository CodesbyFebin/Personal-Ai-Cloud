---
---
<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div>
        <div class="footer__brand">
          <span style="color:var(--color-accent)">◆</span> PersonalAI.cloud
        </div>
        <p class="footer__tagline">Your Personal AI, Everywhere You Are.</p>
      </div>
      <div>
        <h4>Product</h4>
        <ul>
          <li><a href="/whatsapp">WhatsApp</a></li>
          <li><a href="/android">Android</a></li>
          <li><a href="/pricing">Pricing</a></li>
        </ul>
      </div>
      <div>
        <h4>Resources</h4>
        <ul>
          <li><a href="/docs">Docs</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/changelog">Changelog</a></li>
        </ul>
      </div>
      <div>
        <h4>Legal</h4>
        <ul>
          <li><a href="/privacy">Privacy</a></li>
          <li><a href="/terms">Terms</a></li>
          <li><a href="/security">Security</a></li>
        </ul>
      </div>
    </div>
    <div class="footer__bottom">
      <p>© {new Date().getFullYear()} PersonalAI.cloud. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer { border-top: 1px solid var(--color-border); padding: 3rem 0 1.5rem; background: var(--color-surface); }
  .footer__grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 2rem; margin-bottom: 2rem; }
  .footer__brand { font-family: var(--font-display); font-weight: 700; font-size: 1.2rem; margin-bottom: 0.5rem; }
  .footer__tagline { color: var(--color-text-muted); font-size: 0.9rem; }
  .footer h4 { font-size: 0.9rem; margin-bottom: 0.8rem; color: var(--color-text); }
  .footer ul { list-style: none; padding: 0; }
  .footer ul li { margin-bottom: 0.4rem; }
  .footer ul li a { color: var(--color-text-muted); font-size: 0.9rem; transition: 0.2s; text-decoration: none; }
  .footer ul li a:hover { color: var(--color-text); }
  .footer__bottom { border-top: 1px solid var(--color-border); padding-top: 1.5rem; text-align: center; color: var(--color-text-muted); font-size: 0.85rem; }
  @media (max-width: 768px) {
    .footer__grid { grid-template-columns: 1fr 1fr; }
  }
</style>
