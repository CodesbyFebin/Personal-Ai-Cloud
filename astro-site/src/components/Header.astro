---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/whatsapp', label: 'WhatsApp' },
  { href: '/android', label: 'Android' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/use-cases', label: 'Use Cases' },
];
---
<header class="border-b border-stone-200 bg-white/80 backdrop-blur-sm sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="text-2xl font-bold" style="font-family: var(--font-serif); color: var(--color-ink);">
      personalai<span style="color: var(--color-gold);">.cloud</span>
    </a>
    <nav class="hidden md:flex items-center gap-8">
      {navItems.map(item => (
        <a href={item.href} class="text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors">
          {item.label}
        </a>
      ))}
    </nav>
    <a href="/pricing" class="bg-stone-900 text-white px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-stone-800 transition-colors">
      Get Started
    </a>
  </div>
</header>
