---
const { industries } = Astro.props;
---
<section class="industries section section--alt">
  <div class="container">
    <div class="industries__header">
      <span class="section__eyebrow">Who It's For</span>
      <h2 class="section__title">Built to Adapt to <span class="highlight">How You Work</span></h2>
      <p class="section__lead">Illustrative use cases — the same memory engine, applied to different jobs.</p>
    </div>
    <div class="industries__grid">
      {industries.map((ind: any) => (
        <div class="industries__card card">
          <div class="industries__icon">{ind.icon}</div>
          <h3>{ind.name}</h3>
          <p>{ind.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .industries__header { text-align: center; margin-bottom: 3rem; }
  .industries__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.25rem; }
  .industries__card { text-align: center; padding: 1.5rem; }
  .industries__icon { font-size: 2rem; margin-bottom: 0.6rem; }
  .industries__card h3 { font-size: 1.05rem; margin-bottom: 0.4rem; }
  .industries__card p { font-size: 0.9rem; color: var(--color-text-muted); }
</style>
