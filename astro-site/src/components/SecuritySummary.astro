---
const points = [
  { icon: '🔐', title: 'End-to-End Encryption', desc: 'Memory and messages encrypted at rest and in transit with AES-256.' },
  { icon: '🇮🇳', title: 'India Data Residency', desc: 'Hosted in AWS Mumbai (ap-south-1) by default.' },
  { icon: '🛡️', title: 'Compliance', desc: 'GDPR and DPDP aligned, ISO 27001 practices, HIPAA-ready — SOC 2 certification in progress.' },
  { icon: '🚀', title: 'Self-Host Option', desc: 'Run the full stack on your own infrastructure with Docker. 100% data control.' }
];
---
<section class="security section section--alt">
  <div class="container">
    <div class="security__header">
      <span class="section__eyebrow">Security & Privacy</span>
      <h2 class="section__title">Your Data, <span class="highlight">Your Control</span></h2>
    </div>
    <div class="security__grid">
      {points.map(p => (
        <div class="card security__card">
          <div class="security__icon">{p.icon}</div>
          <h3>{p.title}</h3>
          <p>{p.desc}</p>
        </div>
      ))}
    </div>
    <p class="security__link"><a href="/security">Full security & compliance details →</a></p>
  </div>
</section>

<style>
  .security__header { text-align: center; margin-bottom: 3rem; }
  .security__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; }
  .security__icon { font-size: 1.8rem; margin-bottom: 0.6rem; }
  .security__card h3 { font-size: 1.1rem; margin-bottom: 0.4rem; }
  .security__card p { font-size: 0.9rem; color: var(--color-text-muted); }
  .security__link { text-align: center; margin-top: 2.5rem; }
</style>
