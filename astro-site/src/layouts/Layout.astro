---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
export interface Props { title: string; description?: string; lang?: string; schema?: 'website' | 'article' | 'faq' | 'howto' | 'webpage' | 'softwareapplication'; schemaData?: Record<string, any>; structuredData?: Array<Record<string, any>>; }
const { title, description = 'Your Personal AI Assistant', lang = 'en', schema = 'softwareapplication', schemaData = {}, structuredData = [] } = Astro.props;
const langMap: Record<string, string> = { en: 'en_IN', hi: 'hi_IN', ml: 'ml_IN', ta: 'ta_IN' };

const schemaJson = (() => {
  const base = {
    '@context': 'https://schema.org',
    name: title,
    description: description,
    url: `https://personalai.cloud${Astro.url.pathname}`
  };

  switch (schema) {
    case 'website':
      return {
        ...base,
        '@type': 'WebSite',
        potentialAction: {
          '@type': 'SearchAction',
          target: 'https://personalai.cloud/search?q={search_term_string}',
          'query-input': 'required name=search_term_string'
        }
      };
    case 'article':
      return {
        ...base,
        '@type': 'TechArticle',
        headline: title,
        author: { '@type': 'Organization', name: 'PersonalAI', url: 'https://personalai.cloud' },
        publisher: { '@type': 'Organization', name: 'PersonalAI', url: 'https://personalai.cloud' },
        speakable: { '@type': 'SpeakableSpecification', xpath: ['/html/body/main//h1', '/html/body/main//p'] }
      };
    case 'faq':
      return {
        ...base,
        '@type': 'FAQPage',
        mainEntity: []
      };
    case 'howto':
      return {
        ...base,
        '@type': 'HowTo',
        name: title,
        step: []
      };
    case 'webpage':
      return {
        ...base,
        '@type': 'WebPage',
        breadcrumb: {
          '@type': 'BreadcrumbList',
          itemListElement: [
            { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://personalai.cloud/' },
            { '@type': 'ListItem', position: 2, name: title, item: `https://personalai.cloud${Astro.url.pathname}` }
          ]
        }
      };
    case 'softwareapplication':
    default:
      return {
        ...base,
        '@type': 'SoftwareApplication',
        applicationCategory: 'AIApplication',
        operatingSystem: 'Web, Android, WhatsApp',
        author: { '@type': 'Organization', name: 'PersonalAI', url: 'https://personalai.cloud' },
        ...schemaData
      };
  }
})();

const organizationJson = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'PersonalAI',
  url: 'https://personalai.cloud',
  logo: 'https://personalai.cloud/og-image.png',
  sameAs: [
    'https://twitter.com/personalai',
    'https://github.com/CodesbyFebin/Personal-Ai-Cloud',
    'https://linkedin.com/company/personalai'
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'hello@personalai.cloud',
    contactType: 'customer support'
  }
};
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | personalai.cloud</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={`https://personalai.cloud${Astro.url.pathname}`} />
  <link rel="alternate" hrefLang="en" href="https://personalai.cloud/" />
  <link rel="alternate" hrefLang="hi" href="https://personalai.cloud/hi" />
  <link rel="alternate" hrefLang="ml" href="https://personalai.cloud/ml" />
  <link rel="alternate" hrefLang="ta" href="https://personalai.cloud/ta" />
  <link rel="alternate" hrefLang="x-default" href="https://personalai.cloud/" />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://personalai.cloud${Astro.url.pathname}`} />
  <meta property="og:title" content={`${title} | personalai.cloud`} />
  <meta property="og:description" content={description} />
  <meta property="og:site_name" content="PersonalAI" />
  <meta property="og:locale" content={langMap[lang] || 'en_IN'} />
  <meta property="og:image" content="https://personalai.cloud/og-image.png" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | personalai.cloud`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://personalai.cloud/og-image.png" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify(organizationJson)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaJson)} />
  {structuredData.map((item, idx) => <script type="application/ld+json" set:html={JSON.stringify(item)} />)}
  <slot name="head" />
  <style is:global>
    @import '../styles/global.css';
    :root {
      --font-serif: 'Fraunces', Georgia, serif;
      --font-sans: 'Inter', system-ui, sans-serif;
    }
    body {
      font-family: var(--font-sans);
      background: var(--color-bg);
      color: var(--color-text);
    }
  </style>
</head>
<body class="min-h-screen flex flex-col">
  <Header />
  <main class="flex-1"><slot /></main>
  <Footer />
</body>
</html>