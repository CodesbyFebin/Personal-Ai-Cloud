---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
export interface Props { title: string; description?: string; lang?: string; schema?: 'website' | 'article' | 'faq' | 'howto' | 'webpage' | 'softwareapplication'; schemaData?: Record<string, any>; }
const { title, description = 'Your Personal AI Assistant', lang = 'en', schema = 'softwareapplication', schemaData = {} } = Astro.props;
const langMap: Record<string, string> = { en: 'en_IN', hi: 'hi_IN', ml: 'ml_IN', ta: 'ta_IN' };
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | personalai.cloud</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={`https://personalai.cloud${Astro.url.pathname}`} />
  <link rel="alternate" hrefLang="en" href="https://personalai.cloud/" />
  <link rel="alternate" hrefLang="hi" href="https://personalai.cloud/hi" />
  <link rel="alternate" hrefLang="ml" href="https://personalai.cloud/ml" />
  <link rel="alternate" hrefLang="ta" href="https://personalai.cloud/ta" />
  <link rel="alternate" hrefLang="x-default" href="https://personalai.cloud/" />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://personalai.cloud${Astro.url.pathname}`} />
  <meta property="og:title" content={`${title} | personalai.cloud`} />
  <meta property="og:description" content={description} />
  <meta property="og:site_name" content="PersonalAI" />
  <meta property="og:locale" content={langMap[lang] || 'en_IN'} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | personalai.cloud`} />
  <meta name="twitter:description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <slot name="head" />

  {schema === 'website' && JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'PersonalAI',
    url: 'https://personalai.cloud',
    description: description,
    potentialAction: { '@type': 'SearchAction', target: 'https://personalai.cloud/search?q={search_term_string}', 'query-input': 'required name=search_term_string' }
  })}

  {schema === 'article' && JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'TechArticle',
    headline: title,
    description: description,
    url: `https://personalai.cloud${Astro.url.pathname}`,
    author: { '@type': 'Organization', name: 'PersonalAI', url: 'https://personalai.cloud' },
    publisher: { '@type': 'Organization', name: 'PersonalAI', url: 'https://personalai.cloud' },
    speakable: { '@type': 'SpeakableSpecification', xpath: ['/html/body/main//h1', '/html/body/main//p'] }
  })}

  {schema === 'faq' && JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: []
  })}

  {schema === 'howto' && JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: title,
    description: description,
    step: []
  })}

  {schema === 'webpage' && JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description: description,
    url: `https://personalai.cloud${Astro.url.pathname}`,
    breadcrumb: { '@type': 'BreadcrumbList', itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://personalai.cloud/' },
      { '@type': 'ListItem', position: 2, name: title, item: `https://personalai.cloud${Astro.url.pathname}` }
    ]}
  })}

  {schema === 'softwareapplication' && JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'PersonalAI',
    applicationCategory: 'AIApplication',
    operatingSystem: 'Web, Android, WhatsApp',
    description: description,
    url: `https://personalai.cloud${Astro.url.pathname}`,
    author: { '@type': 'Organization', name: 'PersonalAI', url: 'https://personalai.cloud' },
    ...schemaData
  })}

  <style is:global>
    @import '../styles/global.css';
    :root {
      --color-paper: #F7F5F0;
      --color-ink: #1a1a1a;
      --color-gold: #C9A96E;
      --color-gold-dim: #A68B5B;
      --font-serif: 'Fraunces', Georgia, serif;
      --font-sans: 'Inter', system-ui, sans-serif;
    }
    body {
      font-family: var(--font-sans);
      background-color: var(--color-paper);
      color: var(--color-ink);
    }
  </style>
</head>
<body class="min-h-screen flex flex-col">
  <Header />
  <main class="flex-1"><slot /></main>
  <Footer />
</body>
</html>