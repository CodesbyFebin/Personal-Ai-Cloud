---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Android AI App | personalai.cloud" description="Native Android app with FCM push notifications and multi-channel AI support.">
  <article class="max-w-4xl mx-auto px-6 py-12">
    <h1 class="text-5xl font-bold mb-6">Android AI App</h1>
    <p class="text-xl text-stone-600 mb-8">Native Android app with FCM push notifications and multi-channel AI support.</p>

    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-stone-500">
        <li><a href="/" class="hover:text-stone-900">Home</a></li>
        <li>/</li>
        <li class="text-stone-900 font-medium">Android</li>
      </ol>
    </nav>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: "PersonalAI Android",
      applicationCategory: "AIApplication",
      operatingSystem: "Android",
      description: "Native Android app with FCM push notifications and multi-channel AI support.",
      url: "https://personalai.cloud/android",
      author: { "@type": "Organization", name: "PersonalAI", url: "https://personalai.cloud" },
      offers: { "@type": "Offer", price: "0", priceCurrency: "INR" }
    })} />

    <section class="mb-12">
      <h2 class="text-3xl font-bold mb-4">Features</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-xl border border-stone-200 bg-white">
          <h3 class="text-lg font-semibold mb-2">FCM Push Notifications</h3>
          <p class="text-stone-600 text-sm">Real-time notifications for reminders and proactive nudges.</p>
        </div>
        <div class="p-6 rounded-xl border border-stone-200 bg-white">
          <h3 class="text-lg font-semibold mb-2">Offline-First Sync</h3>
          <p class="text-stone-600 text-sm">Your AI works even without internet, then syncs when connected.</p>
        </div>
      </div>
    </section>
  </article>
</Layout>