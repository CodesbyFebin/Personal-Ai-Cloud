---
import Layout from '../../layouts/Layout.astro';
const endpoints = [
  { method: "GET", path: "/api/v2/providers", description: "List AI providers with ratings and features" },
  { method: "GET", path: "/api/v2/providers/{id}", description: "Get details for a specific provider" },
  { method: "GET", path: "/api/v2/comparisons", description: "Compare multiple AI tools" },
  { method: "POST", path: "/api/v2/reviews", description: "Submit a review (authenticated)" },
  { method: "GET", path: "/api/v2/search", description: "Search providers, topics, and content" }
];
---
<Layout title="API Reference | personalai.cloud" description="REST API access to PersonalAI data. Endpoints for providers, comparisons, reviews, and search." schema="webpage">
  <section class="max-w-4xl mx-auto px-6 py-12">
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-stone-500">
        <li><a href="/" class="hover:text-stone-900">Home</a></li>
        <li>/</li>
        <li><a href="/docs" class="hover:text-stone-900">Docs</a></li>
        <li>/</li>
        <li class="text-stone-900 font-medium">API</li>
      </ol>
    </nav>

    <h1 class="text-4xl font-bold mb-4">API Reference</h1>
    <p class="text-xl text-stone-600 mb-10">Access provider data, comparisons, and reviews programmatically.</p>

    <div class="space-y-4">
      {endpoints.map(endpoint => (
        <div class="flex items-center gap-4 rounded-xl border border-stone-200 bg-white p-4">
          <span class={`px-3 py-1 rounded text-sm font-mono font-bold ${endpoint.method === 'GET' ? 'bg-emerald-100 text-emerald-700' : 'bg-blue-100 text-blue-700'}`}>
            {endpoint.method}
          </span>
          <code class="text-stone-700 font-mono">{endpoint.path}</code>
          <span class="text-stone-500 text-sm ml-auto">{endpoint.description}</span>
        </div>
      ))}
    </div>

    <div class="mt-12">
      <a href="/docs" class="inline-block bg-stone-900 text-white px-6 py-3 rounded-lg font-semibold hover:bg-stone-800 transition-colors">Read the Docs</a>
    </div>
  </section>
</Layout>
