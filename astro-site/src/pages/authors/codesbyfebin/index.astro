---
import Layout from '../../../layouts/Layout.astro';
const author = {
  name: 'CodesbyFebin',
  bio: 'Founder & Developer of PersonalAI.cloud — an open-source, self-hostable personal AI platform with persistent memory, built India-first.',
  github: 'https://github.com/CodesbyFebin/Personal-Ai-Cloud'
};
---
<Layout title="CodesbyFebin | personalai.cloud" description="Founder & Developer of PersonalAI.cloud." schema="webpage" schemaData={{
  '@type': 'Person',
  name: author.name,
  description: author.bio,
  url: 'https://personalai.cloud/authors/codesbyfebin',
  sameAs: [author.github],
  worksFor: {
    '@type': 'Organization',
    name: 'PersonalAI',
    url: 'https://personalai.cloud'
  }
}}>
  <article class="max-w-4xl mx-auto px-6 py-12">
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-stone-500">
        <li><a href="/" class="hover:text-stone-900">Home</a></li>
        <li>/</li>
        <li><a href="/about" class="hover:text-stone-900">About</a></li>
        <li>/</li>
        <li class="text-stone-900 font-medium">{author.name}</li>
      </ol>
    </nav>
    <h1 class="text-5xl font-bold mb-6">{author.name}</h1>
    <p class="text-xl text-stone-600 mb-8">{author.bio}</p>
    <div class="flex gap-4">
      <a href={author.github} class="text-stone-600 hover:text-stone-900">GitHub</a>
    </div>
  </article>
</Layout>
