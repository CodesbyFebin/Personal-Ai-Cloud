---
import Layout from '../../../layouts/Layout.astro';
const author = {
  name: 'Priya Sharma',
  bio: 'CTO at PersonalAI. Previously at Google AI and IIT Bombay.',
  twitter: '@priyasharma',
  github: 'priyasharma',
  linkedin: 'priyasharma'
};
---
<Layout title="Priya Sharma | personalai.cloud" description="CTO at PersonalAI. Previously at Google AI and IIT Bombay." schema="webpage" schemaData={{
  '@type': 'Person',
  name: author.name,
  description: author.bio,
  url: 'https://personalai.cloud/authors/priya-sharma',
  sameAs: [
    `https://twitter.com/${author.twitter}`,
    `https://github.com/${author.github}`,
    `https://linkedin.com/in/${author.linkedin}`
  ],
  worksFor: {
    '@type': 'Organization',
    name: 'PersonalAI',
    url: 'https://personalai.cloud'
  }
}}>
  <article class="max-w-4xl mx-auto px-6 py-12">
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-stone-500">
        <li><a href="/" class="hover:text-stone-900">Home</a></li>
        <li>/</li>
        <li><a href="/about" class="hover:text-stone-900">About</a></li>
        <li>/</li>
        <li class="text-stone-900 font-medium">{author.name}</li>
      </ol>
    </nav>
    <h1 class="text-5xl font-bold mb-6">{author.name}</h1>
    <p class="text-xl text-stone-600 mb-8">{author.bio}</p>
    <div class="flex gap-4">
      <a href="https://twitter.com/{author.twitter}" class="text-stone-600 hover:text-stone-900">Twitter</a>
      <a href="https://github.com/{author.github}" class="text-stone-600 hover:text-stone-900">GitHub</a>
      <a href="https://linkedin.com/in/{author.linkedin}" class="text-stone-600 hover:text-stone-900">LinkedIn</a>
    </div>
  </article>
</Layout>