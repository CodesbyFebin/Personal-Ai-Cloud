---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Documentation | personalai.cloud" description="Developer documentation and guides.">
  <article class="max-w-4xl mx-auto px-6 py-12">
    <h1 class="text-5xl font-bold mb-6">Documentation</h1>
    <p class="text-xl text-stone-600 mb-8">Developer documentation and guides.</p>
    <div class="grid md:grid-cols-2 gap-6">
      <a href="/docs/getting-started" class="block p-6 rounded-xl border border-stone-200 bg-white hover:shadow-md transition">
        <h3 class="text-lg font-semibold mb-2">Getting Started</h3>
        <p class="text-stone-600 text-sm">Quick start guide for PersonalAI.</p>
      </a>
      <a href="/docs/whatsapp-setup" class="block p-6 rounded-xl border border-stone-200 bg-white hover:shadow-md transition">
        <h3 class="text-lg font-semibold mb-2">WhatsApp Setup</h3>
        <p class="text-stone-600 text-sm">Connect your AI to WhatsApp.</p>
      </a>
      <a href="/docs/memory-management" class="block p-6 rounded-xl border border-stone-200 bg-white hover:shadow-md transition">
        <h3 class="text-lg font-semibold mb-2">Memory Management</h3>
        <p class="text-stone-600 text-sm">Control your AI's persistent memory.</p>
      </a>
      <a href="/self-hosted" class="block p-6 rounded-xl border border-stone-200 bg-white hover:shadow-md transition">
        <h3 class="text-lg font-semibold mb-2">Self-Hosting</h3>
        <p class="text-stone-600 text-sm">Run PersonalAI on your own hardware.</p>
      </a>
    </div>
  </article>
</Layout>