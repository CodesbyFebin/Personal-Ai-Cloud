---
import Layout from '../layouts/Layout.astro';
const founder = {
  name: 'CodesbyFebin',
  title: 'Founder & Developer',
  bio: 'CodesbyFebin builds PersonalAI.cloud — an open-source, self-hostable personal AI platform focused on persistent memory, WhatsApp integration, and India-first design. The project is developed in the open on GitHub.',
  github: 'https://github.com/CodesbyFebin/Personal-Ai-Cloud'
};
---
<Layout title="CodesbyFebin | personalai.cloud" description="Founder & Developer of PersonalAI. Building an open-source personal AI with persistent memory for India.">
  <section class="max-w-4xl mx-auto px-6 py-12">
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-stone-500">
        <li><a href="/" class="hover:text-stone-900">Home</a></li>
        <li>/</li>
        <li><a href="/about" class="hover:text-stone-900">About</a></li>
        <li>/</li>
        <li class="text-stone-900 font-medium">{founder.name}</li>
      </ol>
    </nav>

    <div class="flex items-start gap-6 mb-10">
      <div class="w-24 h-24 rounded-full bg-stone-200 flex items-center justify-center text-3xl">👤</div>
      <div>
        <h1 class="text-4xl font-bold mb-2">{founder.name}</h1>
        <p class="text-xl text-stone-600">{founder.title}</p>
      </div>
    </div>

    <div class="prose prose-stone max-w-none mb-10">
      <p class="text-stone-700 leading-relaxed">{founder.bio}</p>
    </div>

    <div class="flex gap-4">
      <a href={founder.github} class="text-stone-600 hover:text-stone-900">GitHub</a>
    </div>

    <div class="mt-12 p-6 rounded-xl border border-stone-200 bg-white">
      <h2 class="text-xl font-bold mb-3">Press & Media</h2>
      <p class="text-stone-600 text-sm mb-4">For interviews, speaking engagements, or press inquiries, reach out to hello@personalai.cloud.</p>
      <a href="/press" class="text-sm text-stone-900 underline">Press kit</a>
    </div>
  </section>
</Layout>
