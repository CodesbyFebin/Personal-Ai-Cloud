---
import Layout from '../../layouts/Layout.astro';
const terms = [
  { term: "LLM", full: "Large Language Model", definition: "AI models trained on vast text data to understand and generate human language." },
  { term: "RAG", full: "Retrieval Augmented Generation", definition: "Technique that enhances AI responses by retrieving relevant information from external sources." },
  { term: "Prompt Engineering", definition: "The practice of designing effective inputs to get desired outputs from AI models." },
  { term: "Fine-tuning", definition: "Training an existing model on specific data to improve performance on particular tasks." },
  { term: "Embeddings", definition: "Numerical representations of text that capture semantic meaning for similarity search." },
  { term: "Transformer", definition: "Neural network architecture that revolutionized NLP through self-attention mechanisms." }
];
---
<Layout title="AI Glossary | personalai.cloud" description="Master AI terminology with our glossary. Terms explained in plain English—from LLMs to embeddings to transformers." schema="webpage">
  <section class="max-w-4xl mx-auto px-6 py-12">
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-stone-500">
        <li><a href="/" class="hover:text-stone-900">Home</a></li>
        <li>/</li>
        <li class="text-stone-900 font-medium">Glossary</li>
      </ol>
    </nav>

    <h1 class="text-4xl font-bold mb-4">AI Glossary</h1>
    <p class="text-xl text-stone-600 mb-10">Key terms explained in plain English.</p>

    <div class="space-y-6">
      {terms.map(item => (
        <article class="rounded-xl border border-stone-200 bg-white p-6">
          <div class="flex items-baseline gap-3 mb-2">
            <h2 class="text-xl font-bold text-stone-900">{item.term}</h2>
            {item.full && <span class="text-sm text-stone-500">({item.full})</span>}
          </div>
          <p class="text-stone-700 leading-relaxed">{item.definition}</p>
        </article>
      ))}
    </div>
  </section>
</Layout>
