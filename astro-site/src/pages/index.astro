---
import Layout from '../layouts/Layout.astro';
import features from '../data/features.json';
import providers from '../data/providers.json';
import pricing from '../data/pricing.json';
import industries from '../data/industries.json';
import FeatureCard from '../components/FeatureCard.astro';
import ProviderCard from '../components/ProviderCard.astro';
import PricingCard from '../components/PricingCard.astro';
import TrustBar from '../components/TrustBar.astro';
import WhatIsPersonalAI from '../components/WhatIsPersonalAI.astro';
import WhyItMatters from '../components/WhyItMatters.astro';
import WhyIndia from '../components/WhyIndia.astro';
import MemoryTimeline from '../components/MemoryTimeline.astro';
import IndustryGrid from '../components/IndustryGrid.astro';
import Architecture from '../components/Architecture.astro';
import AIComparisonTable from '../components/AIComparisonTable.astro';
import SecuritySummary from '../components/SecuritySummary.astro';
import DeveloperSection from '../components/DeveloperSection.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTA from '../components/CTA.astro';

const siteUrl = 'https://personalai.cloud';
const pageUrl = `${siteUrl}/`;

const itemList = {
  '@type': 'ItemList',
  name: 'PersonalAI Features',
  itemListElement: features.slice(0, 10).map((f, idx) => ({
    '@type': 'ListItem',
    position: idx + 1,
    item: {
      '@type': 'SoftwareApplication',
      name: f.title,
      description: f.desc,
      url: `${siteUrl}/#features`
    }
  }))
};

const structuredData = [
  {
    '@type': 'WebSite',
    url: siteUrl,
    name: 'PersonalAI.Cloud',
    description: 'India\'s #1 personal AI platform with persistent memory across WhatsApp, Android, and Web.',
    potentialAction: {
      '@type': 'SearchAction',
      target: `${siteUrl}/search?q={search_term_string}`,
      'query-input': 'required name=search_term_string'
    }
  },
  itemList
];
---

<Layout
  title="PersonalAI.Cloud | India's #1 Personal AI Platform - Persistent Memory Across WhatsApp, Android & Web"
  description="One assistant that lives in WhatsApp, on Android, and in your browser. Persistent memory, privacy-first. 8+ AI providers, 90+ free tiers."
  schema="webpage"
  structuredData={structuredData}
>

  <section class="hero section">
    <div class="container hero__grid">
      <div class="hero__copy">
        <span class="section__eyebrow">India's #1 Personal AI Platform</span>
        <h1 class="section__title">Your Personal AI,<br /><span class="highlight">Everywhere You Are</span></h1>
        <p class="section__lead">One assistant that lives in WhatsApp, on Android, and in your browser. Persistent memory, privacy‑first.</p>
        <div class="hero__ctas">
          <a href="https://app.personalai.cloud" class="btn btn--primary btn--lg">🚀 Start Free →</a>
          <a href="/whatsapp" class="btn btn--outline btn--lg">Setup on WhatsApp</a>
        </div>
        <div class="hero__stats">
          <span><strong>8+</strong> AI providers</span>
          <span><strong>90+</strong> free tiers</span>
          <span><strong>3</strong> channels</span>
        </div>
      </div>
      <div class="hero__visual">
        <div class="arch-diagram">
          <div class="arch-node">User</div>
          <div class="arch-arrow">↓</div>
          <div class="arch-node">PersonalAI<br /><small>Gateway</small></div>
          <div class="arch-arrow">↓</div>
          <div class="arch-row">
            <span class="arch-provider">OpenAI</span>
            <span class="arch-provider">Anthropic</span>
            <span class="arch-provider">Groq</span>
            <span class="arch-provider">Ollama</span>
          </div>
          <div class="arch-arrow">↓</div>
          <div class="arch-node">Response</div>
        </div>
      </div>
    </div>
  </section>

  <TrustBar />
  <WhatIsPersonalAI />
  <WhyItMatters />

  <section class="features section section--alt" id="features">
    <div class="container">
      <div class="features__header">
        <span class="section__eyebrow">Features</span>
        <h2 class="section__title">Your AI, <span class="highlight">Upgraded</span></h2>
        <p class="section__lead">Built for how you actually live and work.</p>
      </div>
      <div class="features__grid">
        {features.map(f => <FeatureCard {...f} />)}
      </div>
    </div>
  </section>

  <MemoryTimeline />
  <WhyIndia />

  <section class="providers section" id="providers">
    <div class="container">
      <div class="providers__header">
        <span class="section__eyebrow">Providers</span>
        <h2 class="section__title">Your Choice of <span class="highlight">AI Brain</span></h2>
        <p class="section__lead">8 providers supported. 90+ free tiers available.</p>
      </div>
      <div class="providers__grid">
        {providers.map(p => <ProviderCard {...p} />)}
      </div>
    </div>
  </section>

  <IndustryGrid industries={industries} />
  <Architecture />
  <AIComparisonTable />
  <SecuritySummary />
  <DeveloperSection />

  <section class="pricing section section--alt" id="pricing">
    <div class="container">
      <div class="pricing__header">
        <span class="section__eyebrow">Simple Pricing</span>
        <h2 class="section__title">Start Free. <span class="highlight">Scale as You Grow.</span></h2>
        <p class="section__lead">Transparent Indian pricing. No USD surprises.</p>
      </div>
      <div class="pricing__grid">
        {pricing.map(t => <PricingCard {...t} />)}
      </div>
    </div>
  </section>

  <FAQAccordion />
  <CTA />

  <style>
    .hero { background: var(--color-bg); padding: 4rem 0 6rem; }
    .hero__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
    .hero__ctas { display: flex; flex-wrap: wrap; gap: 1rem; margin: 2rem 0 1.5rem; }
    .hero__stats { display: flex; gap: 2rem; color: var(--color-text-muted); font-size: 0.95rem; flex-wrap: wrap; }
    .hero__stats strong { color: var(--color-text); font-weight: 700; }
    .hero__visual .arch-diagram { background: var(--color-card-bg); border-radius: 1.2rem; padding: 1.5rem; text-align: center; border: 1px solid var(--color-border); }
    .arch-node { font-weight: 600; padding: 0.5rem; background: var(--color-surface); border-radius: 0.5rem; display: inline-block; margin: 0.3rem 0; }
    .arch-arrow { color: var(--color-text-muted); font-size: 1.5rem; }
    .arch-row { display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; margin: 0.5rem 0; }
    .arch-provider { background: var(--color-surface-alt); padding: 0.2rem 0.8rem; border-radius: 999px; font-size: 0.8rem; border: 1px solid var(--color-border); }
    .features__header { text-align: center; margin-bottom: 3rem; }
    .features__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; }
    .features__card { text-align: center; display: block; color: inherit; text-decoration: none; }
    .features__icon { font-size: 3rem; margin-bottom: 1rem; }
    .features__card h3 { font-size: 1.3rem; margin-bottom: 0.5rem; color: var(--color-text); }
    .features__card p { color: var(--color-text-muted); line-height: 1.7; }
    .providers__header { text-align: center; margin-bottom: 3rem; }
    .providers__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1.5rem; }
    .provider__card { text-align: center; }
    .provider__name { font-weight: 700; font-size: 1.1rem; margin-bottom: 0.3rem; }
    .provider__type { color: var(--color-text-muted); font-size: 0.85rem; }
    .provider__strength { color: var(--color-text-muted); font-size: 0.8rem; margin-top: 0.5rem; line-height: 1.5; }
    .pricing__header { text-align: center; margin-bottom: 3rem; }
    .pricing__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 2rem; margin-top: 2rem; }
    .pricing__card { text-align: center; }
    .pricing__card.highlight { border-color: var(--color-accent); box-shadow: 0 0 30px rgba(201,168,76,0.1); }
    .pricing__price { margin: 1rem 0; }
    .pricing__price .amount { font-size: 2.5rem; font-weight: 700; }
    .pricing__price .period { color: var(--color-text-muted); font-size: 1rem; }
    .pricing__card ul { list-style: none; padding: 0; margin: 1.5rem 0; text-align: left; }
    .pricing__card ul li { color: var(--color-text-muted); padding: 0.3rem 0; font-size: 0.9rem; }
    @media (max-width: 768px) {
      .hero__grid { grid-template-columns: 1fr; }
      .hero { min-height: auto; padding: 2rem 0 4rem; }
    }
  </style>
</Layout>
