---
import Layout from '../../layouts/Layout.astro';
const integrations = [
  {
    category: "Communication",
    tools: [
      { name: "WhatsApp", href: "/whatsapp" },
      { name: "Telegram", href: "https://t.me/personalai" },
      { name: "Slack", href: "https://docs.personalai.cloud" },
      { name: "Discord", href: "https://docs.personalai.cloud" }
    ]
  },
  {
    category: "Productivity",
    tools: [
      { name: "Notion", href: "https://docs.personalai.cloud" },
      { name: "Google Calendar", href: "https://docs.personalai.cloud" },
      { name: "Gmail", href: "https://docs.personalai.cloud" },
      { name: "Android App", href: "/android" }
    ]
  },
  {
    category: "Development",
    tools: [
      { name: "GitHub", href: "https://github.com/CodesbyFebin/Personal-Ai-Cloud" },
      { name: "VS Code", href: "https://docs.personalai.cloud" },
      { name: "Cursor", href: "https://docs.personalai.cloud" },
      { name: "API Access", href: "/docs" }
    ]
  },
  {
    category: "Languages",
    tools: [
      { name: "Hindi", href: "/hi" },
      { name: "Malayalam", href: "/ml" },
      { name: "Tamil", href: "/ta" },
      { name: "English", href: "/" }
    ]
  }
];
---
<Layout title="Integrations | personalai.cloud" description="Connect PersonalAI with WhatsApp, Android, Telegram, Notion, GitHub, and more.">
  <section class="max-w-5xl mx-auto px-6 py-12">
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-stone-500">
        <li><a href="/" class="hover:text-stone-900">Home</a></li>
        <li>/</li>
        <li class="text-stone-900 font-medium">Integrations</li>
      </ol>
    </nav>

    <h1 class="text-4xl font-bold mb-4">Integrations</h1>
    <p class="text-xl text-stone-600 mb-10">Connect PersonalAI with the tools and platforms you already use.</p>

    <div class="grid md:grid-cols-2 gap-6">
      {integrations.map(group => (
        <div class="rounded-xl border border-stone-200 bg-white p-6">
          <h2 class="text-lg font-semibold mb-4">{group.category}</h2>
          <div class="flex flex-wrap gap-2">
            {group.tools.map(tool => (
              <a href={tool.href} class="px-3 py-1 rounded-full text-sm border border-stone-200 hover:border-stone-900 hover:text-stone-900 transition">
                {tool.name}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>
