---
import Layout from '.../layouts/Layout.astro';
---
<Layout title="Integrations | personalai.cloud" description="Connect Gmail, Calendar, Notion, Slack and more to your AI assistant.">
  <article class="max-w-4xl mx-auto px-6 py-12">
    <h1 class="text-5xl font-bold mb-6">Integrations</h1>
    <p class="text-xl text-stone-600 mb-8">Connect Gmail, Calendar, Notion, Slack and more to your AI assistant.</p>
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-stone-500">
        <li><a href="/" class="hover:text-stone-900">Home</a></li>
        <li>/</li>
        <li class="text-stone-900 font-medium">Integrations</li>
      </ol>
    </nav>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="p-6 rounded-xl border border-stone-200 bg-white"><h3 class="text-lg font-semibold mb-2">Gmail</h3><p class="text-stone-600 text-sm">AI reads and drafts emails for you.</p></div>
      <div class="p-6 rounded-xl border border-stone-200 bg-white"><h3 class="text-lg font-semibold mb-2">Google Calendar</h3><p class="text-stone-600 text-sm">Smart schedule management.</p></div>
      <div class="p-6 rounded-xl border border-stone-200 bg-white"><h3 class="text-lg font-semibold mb-2">Notion</h3><p class="text-stone-600 text-sm">Sync notes and databases automatically.</p></div>
      <div class="p-6 rounded-xl border border-stone-200 bg-white"><h3 class="text-lg font-semibold mb-2">Slack</h3><p class="text-stone-600 text-sm">Team notifications and summaries.</p></div>
    </div>
  </article>
</Layout>