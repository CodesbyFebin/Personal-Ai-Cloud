---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Pricing Plans | personalai.cloud" description="Simple, transparent pricing for everyone.">
  <article class="max-w-4xl mx-auto px-6 py-12">
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-stone-500">
        <li><a href="/" class="hover:text-stone-900">Home</a></li>
        <li>/</li>
        <li class="text-stone-900 font-medium">Pricing</li>
      </ol>
    </nav>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: "Pricing Plans",
      description: "Simple, transparent pricing for everyone.",
      url: "https://personalai.cloud/pricing",
      breadcrumb: { "@type": "BreadcrumbList", itemListElement: [{ "@type": "ListItem", position: 1, name: "Home", item: "https://personalai.cloud/" }, { "@type": "ListItem", position: 2, name: "Pricing", item: "https://personalai.cloud/pricing" }] }
    })} />

    <h1 class="text-5xl font-bold mb-6">Pricing Plans</h1>
    <p class="text-xl text-stone-600 mb-8">Simple, transparent pricing for everyone.</p>

    <div class="grid md:grid-cols-3 gap-6">
      <div class="p-6 rounded-xl border border-stone-200 bg-white">
        <h3 class="text-lg font-semibold mb-2">Free</h3>
        <p class="text-3xl font-bold mb-4">₹0<span class="text-sm font-normal text-stone-500">/month</span></p>
        <p class="text-stone-600 text-sm mb-4">1 AI agent, basic memory</p>
        <a href="https://app.personalai.cloud" class="block w-full bg-stone-900 text-white text-center px-6 py-3 rounded-lg font-semibold hover:bg-stone-800 transition-colors">Get Started</a>
      </div>
      <div class="p-6 rounded-xl border border-stone-200 bg-white">
        <h3 class="text-lg font-semibold mb-2">Starter</h3>
        <p class="text-3xl font-bold mb-4">₹499<span class="text-sm font-normal text-stone-500">/month</span></p>
        <p class="text-stone-600 text-sm mb-4">5 agents, extended memory</p>
        <a href="https://app.personalai.cloud" class="block w-full bg-stone-900 text-white text-center px-6 py-3 rounded-lg font-semibold hover:bg-stone-800 transition-colors">Get Started</a>
      </div>
      <div class="p-6 rounded-xl border border-stone-200 bg-white">
        <h3 class="text-lg font-semibold mb-2">Pro</h3>
        <p class="text-3xl font-bold mb-4">₹1,499<span class="text-sm font-normal text-stone-500">/month</span></p>
        <p class="text-stone-600 text-sm mb-4">Unlimited agents, priority support</p>
        <a href="https://app.personalai.cloud" class="block w-full bg-stone-900 text-white text-center px-6 py-3 rounded-lg font-semibold hover:bg-stone-800 transition-colors">Get Started</a>
      </div>
    </div>
  </article>
</Layout>