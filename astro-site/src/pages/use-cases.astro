---
import Layout from '.../layouts/Layout.astro';
---
<Layout title="Use Cases | personalai.cloud" description="Students, founders, professionals using PersonalAI.">
  <article class="max-w-4xl mx-auto px-6 py-12">
    <h1 class="text-5xl font-bold mb-6">Use Cases</h1>
    <p class="text-xl text-stone-600 mb-8">Students, founders, professionals using PersonalAI.</p>
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-stone-500">
        <li><a href="/" class="hover:text-stone-900">Home</a></li>
        <li>/</li>
        <li class="text-stone-900 font-medium">Use Cases</li>
      </ol>
    </nav>
    <div class="grid md:grid-cols-2 gap-6">
      <a href="/student" class="block p-6 rounded-xl border border-stone-200 bg-white hover:shadow-md transition"><h3 class="text-lg font-semibold mb-2">Students</h3><p class="text-stone-600 text-sm">AI study buddy for competitive exams.</p></a>
      <a href="/founder" class="block p-6 rounded-xl border border-stone-200 bg-white hover:shadow-md transition"><h3 class="text-lg font-semibold mb-2">Founders</h3><p class="text-stone-600 text-sm">Co-pilot for startups and business.</p></a>
      <a href="/email-triage" class="block p-6 rounded-xl border border-stone-200 bg-white hover:shadow-md transition"><h3 class="text-lg font-semibold mb-2">Email Triage</h3><p class="text-stone-600 text-sm">Automate your inbox.</p></a>
      <a href="/calendar-assistant" class="block p-6 rounded-xl border border-stone-200 bg-white hover:shadow-md transition"><h3 class="text-lg font-semibold mb-2">Calendar</h3><p class="text-stone-600 text-sm">Smart schedule management.</p></a>
    </div>
  </article>
</Layout>