---
// src/components/ChannelGrid.astro
---
<section class="section">
  <h2 class="text-center">One Assistant. <span class="text-thread">Every Device.</span></h2>
  <p class="text-ash text-center max-w-2xl mx-auto mb-12">Your context travels with you seamlessly.</p>
  <div class="grid md:grid-cols-3 gap-8">
    <div class="card">
      <div class="w-14 h-14 bg-thread text-ink rounded-xl flex items-center justify-center mb-4">
        <span class="text-2xl">💬</span>
      </div>
      <h3 class="mb-2">WhatsApp</h3>
      <p class="text-ash text-sm">Send voice notes, get summaries. Set reminders via text. It lives where you already chat.</p>
    </div>
    <div class="card">
      <div class="w-14 h-14 bg-thread text-ink rounded-xl flex items-center justify-center mb-4">
        <span class="text-2xl">📱</span>
      </div>
      <h3 class="mb-2">Android</h3>
      <p class="text-ash text-sm">Native app with deep system integration. Calendar, email, and notification awareness.</p>
    </div>
    <div class="card">
      <div class="w-14 h-14 bg-thread text-ink rounded-xl flex items-center justify-center mb-4">
        <span class="text-2xl">🌐</span>
      </div>
      <h3 class="mb-2">Web Dashboard</h3>
      <p class="text-ash text-sm">Full control center to configure memory, connect integrations, and manage workflows.</p>
    </div>
  </div>
</section>

<style>
  .card {
    background: white;
    border-radius: 1.5rem;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
    border: 1px solid #f0ede8;
  }
</style>