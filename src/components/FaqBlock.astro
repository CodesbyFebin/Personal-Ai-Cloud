---
export interface Props {
  faqs: { q: string; a: string }[];
  pageUrl: string;
}
const { faqs, pageUrl } = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a }
  }))
};
---

<section class="mt-16">
  <h2 class="text-3xl font-display mb-8">Frequently Asked Questions</h2>
  <div class="thread-rail space-y-8">
    {faqs.map((faq) => (
      <div class="relative">
        <span class="thread-node"></span>
        <h3 class="text-lg font-semibold text-paper mb-2">{faq.q}</h3>
        <p class="text-ash" set:html={faq.a} />
      </div>
    ))}
  </div>
</section>
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
