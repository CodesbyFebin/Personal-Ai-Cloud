---
const siteUrl = 'https://personalai.cloud';
---

<header class="border-b border-ash/20 bg-ink/80 backdrop-blur-md sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2">
      <div class="w-8 h-8 rounded-full bg-thread flex items-center justify-center">
        <span class="text-ink font-bold text-sm">P</span>
      </div>
      <span class="font-display font-semibold text-xl text-paper">PersonalAI<span class="text-thread">.cloud</span></span>
    </a>
    <nav class="hidden md:flex items-center gap-8 text-sm font-mono">
      <a href="/personal-ai-assistant/" class="text-ash hover:text-thread transition-colors">About</a>
      <a href="/how-to-create-personal-ai/" class="text-ash hover:text-thread transition-colors">Build</a>
      <a href="/whatsapp-personal-ai/" class="text-ash hover:text-thread transition-colors">WhatsApp</a>
      <a href="/personal-ai-faq/" class="text-ash hover:text-thread transition-colors">FAQ</a>
    </nav>
    <a href="/how-to-create-personal-ai/" class="hidden md:inline-flex px-4 py-2 bg-thread text-ink font-semibold rounded-lg hover:bg-thread/90 transition-colors text-sm">
