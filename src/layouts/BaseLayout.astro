---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  hub: string;
  url: string;
  breadcrumbItems?: { name: string; item: string }[];
}
const { title, description, hub, url, breadcrumbItems = [
  { name: 'Home', item: 'https://personalai.cloud/' },
  { name: title, item: `https://personalai.cloud${url}` }
] } = Astro.props;

const siteJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "PersonalAI.cloud",
  "url": "https://personalai.cloud",
  "logo": "https://personalai.cloud/logo.png"
};

const pageJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": `https://personalai.cloud${url}`,
  breadcrumb: {
    "@type": "BreadcrumbList",
    itemListElement: breadcrumbItems.map((item, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: item.name,
      item: item.item
    }))
  }
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO title={title} description={description} canonical={`https://personalai.cloud${url}`} jsonLd={[siteJsonLd, pageJsonLd]} />
  </head>
  <body>
    <Header />
    <main class="min-h-screen px-6 py-12 md:py-20">
      <slot />
    </main>
    <Footer />
  </body>
</html>
